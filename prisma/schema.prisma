generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum StorePlan {
  STARTER      // 1 loja, 1 integração, até 500 veículos
  PROFESSIONAL // até 5 lojas, 3 integrações, até 5.000 veículos
  ENTERPRISE   // ilimitado
}

enum AdapterType {
  AUTOCERTO    // DMS/Integrador (OAuth2 REST)
  COCKPIT      // DMS popular no Brasil (REST API)
  REVENDA_MAIS // CRM/DMS (REST API)
  MOTOR21      // Integrador (XML/REST)
  WEBMOTORS    // Classificado (API publicação)
  OLX_AUTOS    // Classificado (API publicação)
  MOBIAUTO     // Marketplace (REST API)
  ICARROS      // Classificado (Feed XML)
  REPASSE      // Leilão B2B (REST API)
  MANUAL       // Cadastro manual via admin UI
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  SOLD
  ARCHIVED
}

enum LeadStatus {
  NEW
  AI_QUALIFYING
  QUALIFIED
  HANDOFF_HUMAN
  LOST
  CONVERTED
}

enum SimulationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeadOrigin {
  FACEBOOK_ADS
  GOOGLE_ADS
  ORGANIC
  WHATSAPP
  REFERRAL
  PARTNER
  PLATFORM_WEB
}

enum InteractionChannel {
  WHATSAPP
  EMAIL
  PHONE
  INTERNAL
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

// ─────────────────────────────────────────────────────────────────────────────
// 0. STORES — Tenants (Multi-loja)
// ─────────────────────────────────────────────────────────────────────────────

model Store {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique // subdomínio-ready: viabrasil.superloja.com
  document String?           // CNPJ do operador (opcional)
  plan     StorePlan @default(STARTER)
  isActive Boolean   @default(true)

  partners     Partner[]
  vehicles     Vehicle[]
  leads        Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// 1. PARTNERS — Concessionárias e Lojistas
// ─────────────────────────────────────────────────────────────────────────────

model Partner {
  id       String @id @default(cuid())
  storeId  String
  store    Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name       String
  document   String  @unique // CNPJ (14 dígitos sem pontuação)
  email      String?
  phone      String?
  address    String?
  city       String
  state      String
  commission Float   @default(0.0) // % de success fee negociada
  isActive   Boolean @default(true)

  vehicles     Vehicle[]
  leads        Lead[]
  integrations IntegrationConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, isActive])
  @@index([state, city])
}

// ─────────────────────────────────────────────────────────────────────────────
// 1a. INTEGRATION CONFIGS — Configuração de integrações por parceiro
// ─────────────────────────────────────────────────────────────────────────────

model IntegrationConfig {
  id        String  @id @default(cuid())
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  storeId   String  // denormalizado para queries e RLS

  adapter  AdapterType
  isActive Boolean     @default(true)

  // Credenciais sensíveis (encriptar na camada de aplicação antes de salvar)
  // Estrutura varia por adapter: { clientId, clientSecret, apiUrl, ... }
  credentials Json @default("{}")

  // Config não-sensível: { syncIntervalMinutes, maxVehicles, ... }
  config Json @default("{}")

  lastSyncAt     DateTime?
  lastSyncStatus String?   // "OK" | "ERROR: mensagem"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partnerId, adapter]) // um adapter por parceiro
  @@index([storeId, isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// 2. VEHICLES — Inventário Sincronizado
// ─────────────────────────────────────────────────────────────────────────────

model Vehicle {
  id        String  @id @default(cuid())
  storeId   String  // denormalizado para RLS
  store     Store   @relation(fields: [storeId], references: [id])
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id])

  brand        String
  model        String
  version      String?
  year         Int
  mileage      Int
  price        Decimal @db.Decimal(12, 2)
  fuel         String?
  transmission String?
  color        String?
  description  String? @db.Text
  images       String[]
  videoUrl     String?

  status     VehicleStatus @default(AVAILABLE)
  externalId String?       @unique // deduplicação do sync
  lastSyncAt DateTime      @default(now())

  leads Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, status])
  @@index([partnerId])
  @@index([brand, model])
  @@index([price])
  @@index([year])
}

// ─────────────────────────────────────────────────────────────────────────────
// 3. LEADS — Captura e Qualificação
// ─────────────────────────────────────────────────────────────────────────────

model Lead {
  id      String @id @default(cuid())
  storeId String // denormalizado para RLS
  store   Store  @relation(fields: [storeId], references: [id])

  name  String
  phone String  // Formato: 5511999999999 (Evolution API)
  email String?

  origin LeadOrigin?

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])

  status  LeadStatus @default(NEW)
  score   Int        @default(0)  // 0–100 (IA)
  summary String?    @db.Text

  interactions Interaction[]
  simulations  Simulation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, status])
  @@index([phone])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// 4. INTERACTIONS — Histórico de Conversas
// ─────────────────────────────────────────────────────────────────────────────

model Interaction {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  channel   InteractionChannel
  direction InteractionDirection
  content   String               @db.Text

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// 5. SIMULATIONS — F&I Engine
// ─────────────────────────────────────────────────────────────────────────────

model Simulation {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  vehiclePrice   Decimal @db.Decimal(12, 2)
  downPayment    Decimal @db.Decimal(12, 2)
  financedAmount Decimal @db.Decimal(12, 2)
  installments   Int
  monthlyRate    Float
  monthlyPayment Decimal @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)
  totalInterest  Decimal @db.Decimal(12, 2)

  bankName String?

  status    SimulationStatus @default(PENDING)
  createdAt DateTime         @default(now())

  @@index([leadId])
}
