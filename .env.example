# =============================================================================
# SUPER LOJA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# =============================================================================

# ─── BANCO DE DADOS (Supabase / PostgreSQL) ───────────────────────────────────
# Use a connection string com pooler (porta 6543) para DATABASE_URL
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use a connection string direta (porta 5432) para migrations
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── AUTENTICAÇÃO (Supabase Auth) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# Nunca exponha a service_role key no frontend
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── INVENTÁRIO (AutoCerto API — somente leitura, GET /api/Veiculo/ObterEstoque) ──
AUTOCERTO_API_BASE_URL="https://integracao.autocerto.com"
AUTOCERTO_API_USERNAME="usuario@autocerto.com"
AUTOCERTO_API_PASSWORD="sua-senha-aqui"

# ─── WHATSAPP (Evolution API) ─────────────────────────────────────────────────
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="your-evolution-api-key"
EVOLUTION_INSTANCE_NAME="superloja"

# ─── IA / LLM ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY="sk-ant-..."   # para o agente de qualificação com Claude
# OPENAI_API_KEY="sk-..."          # alternativa com GPT

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Super Loja"
